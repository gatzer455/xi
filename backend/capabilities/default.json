{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "pi",
          "sidecar": true
        },
        {
          "name": "pi-sessions",
          "sidecar": true
        }
      ]
    },
    "shell:allow-spawn",
    "shell:default"
  ]
}
