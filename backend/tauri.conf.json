{
  "productName": "xi",
  "version": "0.1.0",
  "identifier": "com.xi.app",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ./frontend",
    "beforeBuildCommand": "npm run build --prefix ./frontend",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "xi",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/pi", "binaries/pi-sessions"],
    "resources": {
      "binaries/package.json": "package.json"
    },
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5NjhGMUVDMUU3NDU4RjAKUldUd1dIUWU3UEZvU1pObGRhaUlxd0JDNXhZVExua0szZURERHBNZXYxNUJES2RSOEQ4aENjaCsK",
      "endpoints": [],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
