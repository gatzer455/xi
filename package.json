{
  "name": "xi",
  "version": "0.3.6",
  "private": true,
  "description": "Interfaz de escritorio para pi — dirigida a usuarios no-técnicos",
  "scripts": {
    "dev": "bun ./scripts/ensure-sidecars.mjs && cd apps/desktop/backend && bunx tauri dev",
    "build": "bunx tauri build",
    "tauri": "bunx tauri",
    "build-pi": "bun ./scripts/build-pi.mjs",
    "dev:frontend": "cd apps/desktop/frontend && bun run dev",
    "dev:backend": "cd apps/desktop/backend && cargo run",
    "test:e2e": "cd e2e && bun run test",
    "test:e2e:install": "cd e2e && bun install"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.8",
    "@tauri-apps/cli": "^2.11.4",
    "execa": "^9.6.1"
  }
}
