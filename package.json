{
  "name": "xi",
  "version": "0.3.3",
  "private": true,
  "description": "Interfaz de escritorio para pi — dirigida a usuarios no-técnicos",
  "scripts": {
    "dev": "node ./scripts/ensure-sidecars.mjs && npx tauri dev",
    "build": "npx tauri build",
    "tauri": "npx tauri",
    "build-pi": "node ./scripts/build-pi.mjs",
    "dev:frontend": "cd apps/desktop/frontend && npm run dev",
    "dev:backend": "cd apps/desktop/backend && cargo run",
    "test:e2e": "cd e2e && npm test",
    "test:e2e:install": "cd e2e && npm install"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.2",
    "@tauri-apps/cli": "^2.11.2",
    "execa": "^9.6.1"
  }
}
