{
  "name": "xi-frontend",
  "version": "0.1.5",
  "private": true,
  "description": "xi — UI vanilla TypeScript. Sin frameworks, sin dependencias de runtime.",
  "scripts": {
    "typecheck": "tsc --noEmit",
