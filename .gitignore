# OS junk
.DS_Store
Thumbs.db
*~

# Generated by different package managers (npm is the canonical one)
bun.lock
pnpm-lock.yaml

# Env / secrets
.env
.env.local
.env.*.local

# Tauri updater signing keys (NUNCA commitear la private key)
# La pubkey (xi.key.pub) va EMBEBIDA en tauri.conf.json como string,
# no como archivo. La private key (xi.key) queda en ~/.tauri/ y en
# GitHub Secrets. Si algún día la key se mueve al repo, ignoramos.
xi.key
xi.key.pub

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
docs/pi-approve-diagnosis.md

# wdio test artifacts
e2e/test-results/

# Extension bundling
resources/extensions/*
!resources/extensions/.gitkeep
packages/xi-tools/target/
