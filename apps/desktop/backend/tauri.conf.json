{
  "productName": "xi",
  "version": "0.3.4",
  "identifier": "com.xi.app",
  "build": {
    "beforeDevCommand": "cd apps/desktop/frontend && npm run dev",
    "beforeBuildCommand": "cd apps/desktop/frontend && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "xi",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/pi", "binaries/pi-sessions"],
    "resources": {
      "binaries/package.json": "package.json",
      "binaries/theme/dark.json": "theme/dark.json",
      "binaries/theme/light.json": "theme/light.json",
      "binaries/theme/theme-schema.json": "theme/theme-schema.json",
      "../../../resources/extensions/": "extensions/"
    },
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installerHooks": "installer/xi-hooks.nsh"
      }
    },
    "macOS": {
      "dmg": {
        "background": "installer/dmg-background.png",
        "windowSize": {
          "width": 864,
          "height": 664
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1N0M0MDE3RUI2NkQ0MzYKUldRMjFHYnJGMEI4SlYrOEdQS1FJeDkvL1NmMmY3VHJaci9ySG0xd3pOMjc4N1RqM0dXbWIyQVYK",
      "endpoints": ["https://github.com/gatzer455/xi/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
